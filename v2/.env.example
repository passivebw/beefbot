# Copy this file to .env and fill in your values
# ------------------------------------------------

# Bot mode: "paper" = no real orders, "live" = real orders
BOT_MODE=paper

# Kalshi credentials
# Get from: kalshi.com -> Account -> API
KALSHI_API_KEY=b16ab35a-2d26-4bd3-93c6-a1e8fd6c7a95
KALSHI_PRIVATE_KEY_PATH=kalshi_private.pem
KALSHI_ENV=prod

# Binance (optional - public streams don't need auth)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit (optional - OI endpoint is public)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# CoinGlass (optional - bot works without it, just less signal)
COINGLASS_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Storage
DB_PATH=./data/bot.db
